{
  "title": "VocPass",
  "uid": "vocpass-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "Asia/Taipei",
  "tags": ["vocpass"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "label": "節點",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(vocpass_http_requests_total, instance)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2
      },
      {
        "name": "school",
        "type": "query",
        "label": "學校",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(vocpass_school_requests_total, school_name)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2
      },
      {
        "name": "interval",
        "type": "custom",
        "label": "統計區間",
        "query": "15m,30m,1h,3h,6h,12h,24h",
        "current": { "text": "1h", "value": "1h" },
        "options": [
          { "text": "15m", "value": "15m", "selected": false },
          { "text": "30m", "value": "30m", "selected": false },
          { "text": "1h",  "value": "1h",  "selected": true  },
          { "text": "3h",  "value": "3h",  "selected": false },
          { "text": "6h",  "value": "6h",  "selected": false },
          { "text": "12h", "value": "12h", "selected": false },
          { "text": "24h", "value": "24h", "selected": false }
        ],
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "概覽",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "請求總數 ($interval)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(increase(vocpass_http_requests_total[$interval]))", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx 錯誤率",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum(rate(vocpass_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(vocpass_http_requests_total[5m]))",
        "legendFormat": ""
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 延遲",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(vocpass_http_request_duration_seconds_bucket[5m])) by (le))",
        "legendFormat": ""
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "進行中請求",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(vocpass_http_requests_in_flight)", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "支援學校數",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "vocpass_schools_loaded_total", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "應用程式錯誤 ($interval)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(increase(vocpass_errors_total[$interval]))", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } } }
    },

    {
      "id": 10,
      "type": "row",
      "title": "HTTP 流量",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "請求量 (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum by (path) (rate(vocpass_http_requests_total[1m]))",
        "legendFormat": "{{ path }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP 狀態碼分佈",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum by (status_code) (rate(vocpass_http_requests_total[1m]))",
        "legendFormat": "{{ status_code }}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "200" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byRegexp", "options": "4.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byRegexp", "options": "5.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "請求延遲 p50 / p95 / p99",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(vocpass_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "p50 {{ path }}" },
        { "expr": "histogram_quantile(0.95, sum(rate(vocpass_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "p95 {{ path }}" },
        { "expr": "histogram_quantile(0.99, sum(rate(vocpass_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "p99 {{ path }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },

    {
      "id": 20,
      "type": "row",
      "title": "學校爬取",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "各學校查詢量",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum by (school_name, data_type) (rate(vocpass_school_requests_total{school_name=~\"$school\"}[5m]))",
        "legendFormat": "{{ school_name }} / {{ data_type }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "學校爬取延遲 p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, school_name) (rate(vocpass_school_fetch_duration_seconds_bucket{school_name=~\"$school\"}[5m])))",
        "legendFormat": "{{ school_name }}"
      }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 }] } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "學校爬取錯誤",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum by (school_name, error_type) (rate(vocpass_school_fetch_errors_total{school_name=~\"$school\"}[5m]))",
        "legendFormat": "{{ school_name }} / {{ error_type }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "學校爬取回應大小",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, school_name) (rate(vocpass_school_fetch_response_size_bytes_bucket{school_name=~\"$school\"}[5m])))",
        "legendFormat": "{{ school_name }}"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 25,
      "type": "bargauge",
      "title": "各學校登入狀態檢查結果 ($interval)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum by (school_name, result) (increase(vocpass_school_login_checks_total{school_name=~\"$school\", result!=\"attempt\"}[$interval]))",
        "legendFormat": "{{ school_name }} / {{ result }}"
      }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*/ logged_in$" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*/ not_logged_in$" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      }
    },

    {
      "id": 30,
      "type": "row",
      "title": "錯誤 & 系統",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "應用程式錯誤 by type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum by (error_type, school_name) (rate(vocpass_errors_total[5m]))",
        "legendFormat": "{{ error_type }} / {{ school_name }}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Rate Limit 觸發次數",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum by (path) (rate(vocpass_rate_limit_hits_total[5m]))",
        "legendFormat": "{{ path }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 33,
      "type": "bargauge",
      "title": "各 API 版本支援學校數",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "max by (api_version) (vocpass_schools_by_version_total)",
        "legendFormat": "{{ api_version }}"
      }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "公告查詢次數",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum by (school_name, api_version) (rate(vocpass_school_notice_requests_total[5m]))",
        "legendFormat": "{{ school_name }} {{ api_version }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "檢舉次數",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum(rate(vocpass_report_total[5m]))",
        "legendFormat": "reports"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },

    {
      "id": 40,
      "type": "row",
      "title": "Logs (Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 62 },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "logs",
      "title": "錯誤 Logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 63 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "{logger=~\"vocpass.*\", level=\"error\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 42,
      "type": "logs",
      "title": "學校爬取失敗 Logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 73 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "{logger=\"vocpass.school\", level=\"warning\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 43,
      "type": "logs",
      "title": "HTTP 請求 Logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 83 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "{logger=\"vocpass.request\"} | json",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": false, "sortOrder": "Descending", "dedupStrategy": "none" }
    }
  ],

  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ]
}
